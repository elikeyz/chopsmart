# Your AWS region for App Runner (can be any region with App Runner support)
aws_region = "eu-west-1"

# Your OpenAI API key (get from https://platform.openai.com/api-keys)
openai_api_key = "sk-..."

# Bedrock model configuration
# Using Amazon Nova Pro model for better reliability
bedrock_model_id = "eu.amazon.nova-pro-v1:0"

# Bedrock region (us-west-2 has the most models available)
# Note: This can be different from your Lambda region - cross-region calls work fine
bedrock_region = "eu-west-1"
